{
  "name": "family-cookbook",
  "version": "0.1.32",
  "private": true,
  "description": "Family cookbook and meal planning app with Firebase-backed planning workflows.",
  "scripts": {
    "index": "node scripts/index-recipes.js",
    "export:pdf": "node scripts/export-pdf.js",
    "build:app": "node scripts/build-app-data.js",
    "serve:app": "node scripts/serve-app.js",
    "dev": "node scripts/build-app-data.js && vite --host 0.0.0.0",
    "build": "node scripts/build-app-data.js && vite build",
    "build:pages": "node scripts/build-app-data.js && vite build --base=/familycookbook/",
    "preview": "vite preview --host 0.0.0.0",
    "app": "npm run build && vite preview --host 0.0.0.0",
    "deploy:pages": "node scripts/deploy-github-pages.js",
    "apply:feedback": "node scripts/apply-recipe-feedback.js",
    "sync:feedback": "node scripts/sync-recipe-feedback.js",
    "migrate:firebase": "node scripts/migrate-week-lists-to-firebase.js",
    "import:recipes": "node scripts/import-recipes-to-firebase.js"
  },
  "dependencies": {
    "@tesseract.js-data/eng": "^1.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "firebase": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tesseract.js": "^7.0.0",
    "vite": "^7.0.0"
  }
}
