rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isFamilyHousehold(householdId) {
      return householdId == "family";
    }

    match /households/{householdId}/groceryWeeks/{weekId} {
      allow read, write: if isFamilyHousehold(householdId);
    }

    match /households/{householdId}/prepWeeks/{weekId} {
      allow read, write: if isFamilyHousehold(householdId);
    }

    match /households/{householdId}/weeklyPlans/{weekId} {
      allow read, write: if isFamilyHousehold(householdId);
    }

    match /households/{householdId}/workingWeeks/{docId} {
      allow read, write: if isFamilyHousehold(householdId);
    }

    match /households/{householdId}/weeks/{weekId} {
      allow read, write: if isFamilyHousehold(householdId);
    }

    match /households/{householdId}/recipeFeedback/{recipeId} {
      allow read, write: if isFamilyHousehold(householdId);
    }

    match /households/{householdId}/recipes/{recipeId} {
      allow read, write: if isFamilyHousehold(householdId);
    }

    match /households/{householdId}/recipes/{recipeId}/reviews/{reviewId} {
      allow read, write: if isFamilyHousehold(householdId);
    }
  }
}
